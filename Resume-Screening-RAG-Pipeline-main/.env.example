# LLM provider used by the Streamlit app.
# Supported values: Ollama, Gemini
LLM_PROVIDER=Ollama

# Ollama runs locally and does not need an API key.
OLLAMA_MODEL=llama3

# Gemini requires one of these API keys.
GEMINI_MODEL=gemini-3.5-flash
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Optional values used by demo/interactive/ingest_data.py.
DATA_PATH=data/main-data/synthetic-resumes.csv
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FAISS_PATH=vectorstore
